{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rl-excavator.local/schemas/rrt_star_request.schema.json",
  "title": "RL Excavator RRT Star Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_s",
    "frame_id",
    "task_mode",
    "start_bucket_tip_base",
    "goal",
    "ground",
    "obstacles",
    "planning_params"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "rrt_star_request.v1"
    },
    "timestamp_s": {
      "type": "number"
    },
    "frame_id": {
      "type": "string"
    },
    "task_mode": {
      "type": "string",
      "enum": [
        "MoveToDig",
        "CarryMaterial"
      ]
    },
    "start_bucket_tip_base": {
      "$ref": "#/$defs/vec3"
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "position_m",
        "normal",
        "radius_m",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "dig",
            "dump"
          ]
        },
        "position_m": {
          "$ref": "#/$defs/vec3"
        },
        "normal": {
          "$ref": "#/$defs/vec3"
        },
        "radius_m": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "mission": {
          "$ref": "#/$defs/mission_reference"
        }
      }
    },
    "ground": {
      "type": "object"
    },
    "obstacles": {
      "type": "array"
    },
    "planning_params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waypoint_lookahead",
        "target_threshold",
        "tube_radius"
      ],
      "properties": {
        "waypoint_lookahead": {
          "type": "integer",
          "minimum": 1
        },
        "target_threshold": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "tube_radius": {
          "type": "number",
          "exclusiveMinimum": 0.0
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "mission_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256", "phase"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "phase": {"enum": ["dig", "dump"]}
      }
    },
    "vec3": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 3,
      "maxItems": 3
    }
  }
}
